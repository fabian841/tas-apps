# Google Drive OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Workspace root folder (TAS shared drive)
WORKSPACE_FOLDER_ID=1klBbAXcsqy0yYi_MAgLZJj_Pg7xEsCWm

# n8n — Required for Phase 1 (workflow cleanup)
# Base URL of your n8n instance (no trailing slash)
# Examples: https://n8n.yourdomain.com  or  http://localhost:5678
N8N_BASE_URL=
# API key from n8n Settings > API > Create API Key
N8N_API_KEY=

# Central audit Google Sheet — all 3 N8N workflows log here
# Create a Google Sheet called "TAS_N8N_Audit" with tabs:
#   Stale_Workflows | Execution_Cleanup | Workflow_Organisation
# Paste the Sheet ID from the URL: docs.google.com/spreadsheets/d/{THIS_PART}/edit
TAS_AUDIT_SHEET_ID=

# Google account (used for email notifications)
GOOGLE_ACCOUNT=fabian@fdnxt.com

# Phase 6 — Gmail Email Filing Agent
# Gmail label to watch (emails with this label will be processed)
GMAIL_FILING_LABEL=TO FILE
# Archive emails after filing? (true/false)
GMAIL_ARCHIVE_AFTER_FILING=true
