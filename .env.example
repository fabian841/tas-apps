# LIFE OS – Environment Variables Template
# Copy to /opt/fabian-os/.env and fill in actual values. Set permissions: chmod 600 .env
# NEVER commit .env to Git.

# ── Database ──────────────────────────────────────────
POSTGRES_PASSWORD=<strong_password>
APP_DB_PASSWORD=<app_password>

# ── n8n ───────────────────────────────────────────────
N8N_ENCRYPTION_KEY=<random_32_char_key>

# ── Healthchecks.io ──────────────────────────────────
HC_BACKUP_UUID=<your_uuid>

# ── Gmail (both inboxes) ────────────────────────────
GMAIL_CREDENTIALS_PATH=/opt/fabian-os/secrets/gmail_credentials.json

# ── Google Calendar (for Morning Pulse) ──────────────
GOOGLE_CALENDAR_ICAL_URL=<your_google_calendar_ical_url>

# ── Google Drive (00_INBOX folder ID) ────────────────
GOOGLE_DRIVE_INBOX_FOLDER_ID=<folder_id>

# ── Microsoft 365 (forwarded to Gmail) ──────────────
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_TENANT_ID=

# ── Claude API (Phase 1 – PLAUD extraction) ─────────
CLAUDE_API_KEY=<your_claude_api_key>

# ── Google Sheets (Phase 1 – PIL registers) ─────────
GOOGLE_SHEETS_CREDENTIALS_PATH=/opt/fabian-os/secrets/sheets_credentials.json
PIL_REGISTER_SHEET_ID=<google_sheet_id>

# ── Zoho (Phase 2) ──────────────────────────────────
# ZOHO_CLIENT_ID=
# ZOHO_CLIENT_SECRET=

# ── Xero (Phase 2) ──────────────────────────────────
# XERO_CLIENT_ID=
# XERO_CLIENT_SECRET=
# XERO_TENANT_ID=

# ── Perplexity API (Phase 3+) ───────────────────────
# PERPLEXITY_API_KEY=
