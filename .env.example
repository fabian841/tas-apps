# Fabian OS – Environment Variables Template
# Copy to .env and fill in actual values. Set permissions: chmod 600 .env
# NEVER commit .env to Git.

# ── Database ──────────────────────────────────────────
POSTGRES_PASSWORD=<strong_password>
APP_DB_PASSWORD=<app_password>

# ── n8n ───────────────────────────────────────────────
N8N_ENCRYPTION_KEY=<random_32_char_key>

# ── Healthchecks.io ──────────────────────────────────
HC_BACKUP_UUID=<your_uuid>

# ── Gmail ─────────────────────────────────────────────
GMAIL_CREDENTIALS_PATH=/opt/fabian-os/secrets/gmail_credentials.json

# ── Microsoft 365 ────────────────────────────────────
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_TENANT_ID=

# ── Google Drive ─────────────────────────────────────
DRIVE_CREDENTIALS_PATH=/opt/fabian-os/secrets/drive_credentials.json

# ── Zoho (Phase 1) ──────────────────────────────────
# ZOHO_CLIENT_ID=
# ZOHO_CLIENT_SECRET=

# ── Xero (Phase 1) ──────────────────────────────────
# XERO_CLIENT_ID=
# XERO_CLIENT_SECRET=

# ── Claude API (Phase 0 – optional for classification) ─
# CLAUDE_API_KEY=

# ── Perplexity API (Phase 2+) ────────────────────────
# PERPLEXITY_API_KEY=
