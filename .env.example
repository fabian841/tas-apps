# LIFE OS – Environment Variables Template
# Copy to /opt/fabian-os/.env and fill in actual values. Set permissions: chmod 600 .env
# NEVER commit .env to Git.

# ── Database ──────────────────────────────────────────
POSTGRES_PASSWORD=<strong_password>
APP_DB_PASSWORD=<app_password>

# ── n8n ───────────────────────────────────────────────
N8N_ENCRYPTION_KEY=<random_32_char_key>

# ── Healthchecks.io ──────────────────────────────────
HC_BACKUP_UUID=<your_uuid>

# ── Gmail (both inboxes) ────────────────────────────
GMAIL_CREDENTIALS_PATH=/opt/fabian-os/secrets/gmail_credentials.json

# ── Google Calendar (for Morning Pulse) ──────────────
GOOGLE_CALENDAR_ICAL_URL=<your_google_calendar_ical_url>

# ── Google Drive (00_INBOX folder ID) ────────────────
GOOGLE_DRIVE_INBOX_FOLDER_ID=<folder_id>

# ── Microsoft 365 (forwarded to Gmail) ──────────────
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_TENANT_ID=

# ── Claude API (Phase 1 – PLAUD extraction) ─────────
CLAUDE_API_KEY=<your_claude_api_key>

# ── Google Sheets (Phase 1 – PIL registers) ─────────
GOOGLE_SHEETS_CREDENTIALS_PATH=/opt/fabian-os/secrets/sheets_credentials.json
PIL_REGISTER_SHEET_ID=<google_sheet_id>

# ── Zoho CRM/Desk/Books (Phase 2 – Company OS) ──────
ZOHO_CLIENT_ID=<your_zoho_client_id>
ZOHO_CLIENT_SECRET=<your_zoho_client_secret>
ZOHO_REFRESH_TOKEN=<your_zoho_refresh_token>
ZOHO_ORG_ID=<your_zoho_org_id>

# ── Xero (Phase 2 – accounting) ─────────────────────
XERO_CLIENT_ID=<your_xero_client_id>
XERO_CLIENT_SECRET=<your_xero_client_secret>
XERO_TENANT_ID=<your_xero_tenant_id>

# ── Claude Code Agents (Phase 3) ───────────────────
# Claude API key is shared with Phase 1 extraction (CLAUDE_API_KEY above).
# Agent sessions use claude --print for non-interactive mode.
# MCP servers read credentials from the vars above (Zoho, Sheets, DB).

# ── Perplexity API (Competitor Intelligence) ────────
PERPLEXITY_API_KEY=<your_perplexity_api_key>

# ── Xero Access Token (managed by n8n credential) ──
XERO_ACCESS_TOKEN=<managed_by_n8n_oauth2>

# ── n8n API (workflow import) ───────────────────────
N8N_API_KEY=<generate_in_n8n_settings_api>
