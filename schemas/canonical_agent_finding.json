{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fabian-os/schemas/canonical_agent_finding.json",
  "title": "Canonical Agent Finding",
  "description": "Structured output from AI research agents",
  "type": "object",
  "required": ["agent_name", "finding_type", "title", "source_system"],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "agent_name": { "type": "string", "minLength": 1 },
    "finding_type": {
      "type": "string",
      "enum": ["competitor_intel", "market_insight", "regulatory_update", "technology_trend", "opportunity", "risk", "other"],
      "minLength": 1
    },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string" },
    "detail": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "relevance_score": { "type": "integer", "minimum": 0, "maximum": 10 },
    "action_required": { "type": "boolean", "default": false },
    "tags": { "type": "array", "items": { "type": "string" } },
    "raw_output_id": { "type": "string", "format": "uuid" },
    "source_system": { "type": "string", "minLength": 1 },
    "external_id": { "type": "string" },
    "metadata": { "type": "object", "default": {} },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
