{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "canonical_deal",
  "description": "Normalised deal/opportunity record from any CRM source",
  "type": "object",
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "source_system": { "type": "string", "description": "Origin system (e.g. zoho, hubspot)" },
    "external_id": { "type": "string", "description": "ID in the source system" },
    "name": { "type": "string" },
    "stage": { "type": "string" },
    "value": { "type": "number" },
    "currency": { "type": "string", "maxLength": 3 },
    "owner": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "metadata": { "type": "object" }
  },
  "required": ["source_system", "external_id"]
}
