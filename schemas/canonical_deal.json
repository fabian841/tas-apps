{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fabian-os/schemas/canonical_deal.json",
  "title": "Canonical Deal",
  "description": "Sales opportunity or business deal",
  "type": "object",
  "required": ["name", "stage", "status", "source_system"],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "name": { "type": "string", "minLength": 1 },
    "stage": {
      "type": "string",
      "enum": ["lead", "qualified", "proposal", "negotiation", "won", "lost"],
      "default": "lead"
    },
    "status": {
      "type": "string",
      "enum": ["open", "won", "lost", "on_hold"],
      "default": "open"
    },
    "value_amount": { "type": "number", "minimum": 0 },
    "value_currency": { "type": "string", "default": "AUD", "pattern": "^[A-Z]{3}$" },
    "contact_id": { "type": "string", "format": "uuid" },
    "company_name": { "type": "string" },
    "description": { "type": "string" },
    "expected_close_date": { "type": "string", "format": "date" },
    "actual_close_date": { "type": "string", "format": "date" },
    "probability": { "type": "integer", "minimum": 0, "maximum": 100 },
    "tags": { "type": "array", "items": { "type": "string" } },
    "source_system": { "type": "string", "minLength": 1 },
    "external_id": { "type": "string" },
    "metadata": { "type": "object", "default": {} },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
