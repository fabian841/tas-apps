{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fabian-os/schemas/canonical_product.json",
  "title": "Canonical Product",
  "description": "Product, service, or offering",
  "type": "object",
  "required": ["name", "product_type", "status", "source_system"],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "product_type": {
      "type": "string",
      "enum": ["software", "hardware", "service", "subscription", "other"],
      "default": "software"
    },
    "status": {
      "type": "string",
      "enum": ["concept", "development", "active", "deprecated", "retired"],
      "default": "concept"
    },
    "version": { "type": "string" },
    "price_amount": { "type": "number", "minimum": 0 },
    "price_currency": { "type": "string", "default": "AUD", "pattern": "^[A-Z]{3}$" },
    "category": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "source_system": { "type": "string", "minLength": 1 },
    "external_id": { "type": "string" },
    "metadata": { "type": "object", "default": {} },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
