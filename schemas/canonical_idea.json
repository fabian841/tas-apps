{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fabian-os/schemas/canonical_idea.json",
  "title": "Canonical Idea",
  "description": "Business idea, product concept, or opportunity",
  "type": "object",
  "required": ["title", "status", "source_system"],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "category": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["captured", "evaluating", "approved", "in_progress", "completed", "rejected", "parked"],
      "default": "captured"
    },
    "priority": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"],
      "default": "medium"
    },
    "feasibility_score": { "type": "integer", "minimum": 0, "maximum": 10 },
    "impact_score": { "type": "integer", "minimum": 0, "maximum": 10 },
    "tags": { "type": "array", "items": { "type": "string" } },
    "related_ideas": { "type": "array", "items": { "type": "string", "format": "uuid" } },
    "source_system": { "type": "string", "minLength": 1 },
    "external_id": { "type": "string" },
    "metadata": { "type": "object", "default": {} },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
